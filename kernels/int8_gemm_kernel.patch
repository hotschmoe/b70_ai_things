+torch::Tensor int8_gemm_w8a16(
+    const torch::Tensor& A,  // src, [b, m, k] f16/bf16
+    const torch::Tensor& B,  // quantized weight, [k, n] s8 (NT)
+    const std::optional<torch::Tensor>&
+        B_scale_,  // per-channel [n] / per-tensor [1] / block [k/g, n]
+    const std::optional<torch::Tensor>& bias_) {
+  const at::DeviceGuard device_guard(A.device());
+  torch::Tensor result = check_and_create_output_tensor(A, B, A.scalar_type());
+  TORCH_CHECK(
+      B.scalar_type() == at::ScalarType::Char,
+      "int8_gemm_w8a16 expects s8 (torch.int8) weight.");
+  TORCH_CHECK(
+      result.scalar_type() == torch::kFloat16 ||
+          result.scalar_type() == torch::kBFloat16,
+      "output must be float16 or bfloat16 for int8 w8a16 matmul");
+
+  // check if nt format (weight stored transposed [k, n] with stride k-major)
+  bool is_nt = B.strides()[B.dim() - 2] == 1;
+
+  torch::Tensor B_scale = B_scale_.has_value()
+                              ? B_scale_.value()
+                              : at::ones({1}, B.options().dtype(A.dtype()));
+  oneDNN::dnnl_matmul_w8a16_int8(result, A, B, is_nt, bias_, B_scale);
+  return result;
+}
