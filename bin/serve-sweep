#!/usr/bin/env bash
# bin/serve-sweep -- the SWEEP GATE harness (ORGANIZATION.md / CLAUDE.md).
#
# Any change to shared serve infra (rdy_to_serve/_common/ OR bin/) is not "done" until this is GREEN
# across ALL rdy_to_serve models. Two tiers:
#   --smoke  (default, MANDATORY)  per model: start -> /health -> 1 gen token -> stop. Catches
#                                  "no longer boots / no longer generates" fast (run eager for speed).
#   --bench  (REQUIRED if a change could move perf)  per model: full serve + concurrency sweep + stop.
#
# Runs ON THE GPU HOST. Serialized through gpu-run (one B70 lease at a time). Iterates every
# rdy_to_serve/<model>/serve.sh (skips dirs starting with _, e.g. _common).
#
#   cd /mnt/vm_8tb/b70
#   bin/serve-sweep --smoke              # or --bench ; or a specific model: bin/serve-sweep --smoke qwen36-27b-int4
set -uo pipefail
ROOT="${ROOT:-/mnt/vm_8tb/b70}"
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"   # serve-sweep lives in <repo>/bin/
RTS="${RTS:-$REPO_DIR/rdy_to_serve}"                          # the shelf is in the repo, not under $ROOT
GPURUN="${GPURUN:-$ROOT/gpu-run}"

MODE=smoke; ONLY=""
for a in "$@"; do
  case "$a" in
    --smoke) MODE=smoke ;;
    --bench) MODE=bench ;;
    --*) echo "unknown flag: $a"; exit 2 ;;
    *) ONLY="$a" ;;
  esac
done
ACTION=smoke; [ "$MODE" = bench ] && ACTION=run    # smoke -> serve.sh smoke ; bench -> serve.sh run

# smoke forces eager (GRAPH=0) for a fast boot check; bench honors each entry's OWN GRAPH
# default (a per-model best setting) unless the caller explicitly set GRAPH (e.g. GRAPH=1 bin/serve-sweep).
if [ "$MODE" = smoke ]; then GRAPH_ENV="GRAPH=${GRAPH:-0}"; else GRAPH_ENV="${GRAPH:+GRAPH=$GRAPH}"; fi

declare -a NAMES RESULTS
# shelf is split by backend: rdy_to_serve/<backend>/<model-quant>/serve.sh (_common is one level, skipped).
for d in "$RTS"/*/*/; do
  rel="${d#"$RTS"/}"; rel="${rel%/}"               # e.g. sglang/qwen36-27b-w8a8
  m="$rel"
  case "$rel" in _*) continue ;; esac              # defensive; _common won't match */*/ anyway
  [ -f "$d/serve.sh" ] || continue
  # ONLY matches: full rel (sglang/qwen36-27b-w8a8), basename (qwen36-27b-w8a8), or backend prefix (vllm).
  [ -n "$ONLY" ] && [ "$m" != "$ONLY" ] && [ "${rel##*/}" != "$ONLY" ] && [ "${rel%%/*}" != "$ONLY" ] && continue
  echo
  echo "########## serve-sweep [$MODE] $m ##########"
  if env $GRAPH_ENV "$GPURUN" bash "$d/serve.sh" "$ACTION"; then
    NAMES+=("$m"); RESULTS+=("PASS")
  else
    NAMES+=("$m"); RESULTS+=("FAIL")
    bash "$d/serve.sh" stop >/dev/null 2>&1 || true   # ensure released on failure
  fi
done

echo
echo "================ serve-sweep summary ($MODE) ================"
fail=0
for i in "${!NAMES[@]}"; do
  printf "  %-8s %s\n" "${RESULTS[$i]}" "${NAMES[$i]}"
  [ "${RESULTS[$i]}" = FAIL ] && fail=1
done
[ "$fail" = 0 ] && echo "ALL GREEN" || echo "RED -- gate NOT satisfied"
exit $fail
