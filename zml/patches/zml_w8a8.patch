+                const vd: i64 = 8;
+                const qkv_shape = Shape.init(.{ .s = s, .h = h, .k = kd }, .f32);
+                const val_shape = Shape.init(.{ .s = s, .h = h, .v = vd }, .f32);
+                const g_shape = Shape.init(.{ .s = s, .h = h }, .f32);
