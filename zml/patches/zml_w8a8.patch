+
+    // ---- Chunked (parallel) gated-delta-rule scan -------------------------------------------
+    // FLA "chunk_gated_delta_rule" WY / UT-transform form, expressed in pure zml ops (cumsum +
+    // triangular masks + batched matmuls + a finite Neumann inverse). Numerically equivalent to
+    // the per-token `forward` scan above but O(s/C) sequential chunk-steps instead of O(s) token-
+    // steps, so it amortizes the MTP verify and cuts prefill TTFT. Everything is f32 (the caller
+    // already upcasts). Chunking is what keeps the f32 exp() of the cumulative log-gate from
+    // underflowing on long sequences (each chunk's cumsum is local). See zml/ZML_GDN_OPT.md and the
+    // machine-precision numpy reference; validated by "gated delta net chunked parity".
+
+    /// Batched matrix product over the (.i, .j) axes: A{..,i,j} @ B{..,i,j} -> {..,i,j},
+    /// contracting A's .j with B's .i. Other shared tags (batch/head) ride along as batch axes.
+    fn matmulIJ(a: Tensor, b: Tensor) Tensor {
+        // Relabel B{..,i,j} -> {..,j,m} for the contraction. Done as two sequential renames because
+        // a simultaneous .i=.j,.j=.m swap transiently duplicates .j (rejected by rename).
+        const b_jm = b.rename(.{ .j = .m }).rename(.{ .i = .j });
+        return a.dot(b_jm, .j).rename(.{ .m = .j });
+    }
+
+    /// f32 identity over the (.i, .j) axes matching `like`'s shape (1 on the diagonal, else 0).
+    fn eyeIJ(like: Tensor) Tensor {
+        const ii = Tensor.iota(like.shape(), .i);
+        const jj = Tensor.iota(like.shape(), .j);
+        const ones = Tensor.scalar(1.0, .f32).broad(like.shape());
+        const zeros = Tensor.scalar(0.0, .f32).broad(like.shape());
+        return ii.cmp(.EQ, jj).select(ones, zeros);
+    }
+
+    /// Sum of the finite Neumann series `I + N + N^2 + ... + N^{l-1}` for a strictly-lower
+    /// (nilpotent, N^l = 0) matrix N over the (.i, .j) axes, built by ceil(log2 l) iterative
+    /// doubling (T_{2p} = T_p (I + N^p)). Exact by nilpotency. To invert (I + A) with A
+    /// strictly-lower, pass N = -A (then this returns (I + A)^{-1}). All f32.
+    fn neumannInverseIJ(n_mat: Tensor, l: i64) Tensor {
+        var t = eyeIJ(n_mat);
+        var np = n_mat;
+        var p: i64 = 1;
+        while (p < l) : (p *= 2) {
+            t = t.add(matmulIJ(t, np));
+            np = matmulIJ(np, np);
+        }
+        return t;
+    }
+
+    /// One chunk of the chunked scan. Processes L positions in parallel (tag .p, L = q.dim(.p))
+    /// continuing from `s_prev` {..,v,k}; returns chunk outputs {..,h,p,v} and updated state
+    /// {..,v,k}. `g` is the LOG forget-gate (not exp(g)); `q` is assumed pre-scaled by the caller.
+    fn chunkStep(q: Tensor, k: Tensor, v: Tensor, g: Tensor, beta: Tensor, s_prev: Tensor) struct { Tensor, Tensor } {
+        const l = q.dim(.p);
+        const gcs = g.cumulativeSum(.p); // inclusive within-chunk cumulative log-gate {..,p,h}
+
+        const ki = k.rename(.{ .p = .i });
+        const kj = k.rename(.{ .p = .j });
+        const qi = q.rename(.{ .p = .i });
+        const vj = v.rename(.{ .p = .j });
+        const beta_i = beta.rename(.{ .p = .i });
+        const beta_j = beta.rename(.{ .p = .j });
+        const gcs_i = gcs.rename(.{ .p = .i });
+        const gcs_j = gcs.rename(.{ .p = .j });
+
+        // decay[i,j] = exp(gcs_i - gcs_j); on the used (lower) triangles gcs_i - gcs_j <= 0.
+        const kk = ki.dot(kj, .k); // {..,h,i,j}
+        const decay = gcs_i.broad(kk.shape()).sub(gcs_j.broad(kk.shape())).exp();
+
+        // A[i,j] = beta_i * (k_i . k_j) * decay, STRICTLY lower (i>j). T = (I + A)^{-1} = sum(-A)^p.
+        const a_mat = beta_i.broad(kk.shape()).mul(kk).mul(decay).triangular(.{ .i, .j }, -1);
+        const t_mat = neumannInverseIJ(a_mat.negate(), l);
+
+        // WY vectors: u = T @ (beta*v); w = T @ (beta * exp(gcs) * k).
+        const d_j = gcs_j.exp();
+        const u = t_mat.dot(vj.mul(beta_j.broad(vj.shape())), .j); // {..,h,i,v}
+        const w = t_mat.dot(kj.mul(beta_j.broad(kj.shape())).mul(d_j.broad(kj.shape())), .j); // {..,h,i,k}
+
+        // Pseudo-values and output (intra term INCLUSIVE of the diagonal -> current token counts).
+        const v_new = u.sub(w.dot(s_prev, .k)); // {..,h,i,v}
+        const d_i = gcs_i.exp();
+        const o_inter = qi.dot(s_prev, .k).mul(d_i.broad(u.shape())); // {..,h,i,v}
+        const aqk = qi.dot(kj, .k).mul(decay).triangular(.{ .i, .j }, 0); // inclusive (i>=j)
+        const intra = aqk.dot(v_new.rename(.{ .i = .j }), .j); // {..,h,i,v}
+        const o = o_inter.add(intra).rename(.{ .i = .p }); // {..,h,p,v}; q pre-scaled -> no extra scale
+
+        // State carry: S' = exp(gcs_last)*S + sum_m exp(gcs_last - gcs_m) * v_new_m (x) k_m.
+        const gcs_last = gcs.slice1d(.p, .{ .start = l - 1, .end = l }).squeeze(.p); // {..,h}
+        const gcs_m = gcs.rename(.{ .p = .m });
+        const coeff = gcs_last.broad(gcs_m.shape()).sub(gcs_m).exp(); // {..,m,h}
+        const v_new_m = v_new.rename(.{ .i = .m });
+        const carry = v_new_m.mul(coeff.broad(v_new_m.shape())).dot(k.rename(.{ .p = .m }), .m); // {..,h,v,k}
+        const s_new = s_prev.mul(gcs_last.exp().broad(s_prev.shape())).add(carry);
+
+        return .{ o, s_new };
+    }
+
+    /// Chunked/parallel gated-delta-rule scan -- a drop-in for `forward` at s>1. Splits the s
+    /// positions into chunks of `chunk_size` (last chunk may be shorter), processes each chunk with
+    /// `chunkStep`, and threads the recurrent state across chunks with a Zig-unrolled loop. Same
+    /// Output as `forward`; `queries` pre-scaled and `alphas` = exp(log-gate), exactly as `forward`.
+    pub fn forwardChunked(
+        queries: Tensor,
+        keys: Tensor,
+        values: Tensor,
+        alphas: Tensor,
+        betas: Tensor,
+        initial_state: State,
+        chunk_size: i64,
+    ) Output {
+        stdx.debug.assert(queries.shape().hasTags(.{ .s, .h, .k }), "GatedDeltaNet.forwardChunked: queries missing {{.s,.h,.k}} ({f})", .{queries});
+        stdx.debug.assert(initial_state.s.shape().hasTags(.{ .h, .v, .k }), "GatedDeltaNet.forwardChunked: initial_state.s missing {{.h,.v,.k}} ({f})", .{initial_state.s});
+
+        const s = queries.dim(.s);
+        const c_eff = @min(chunk_size, s);
+        const g = alphas.log(); // recover the log-gate (alphas = exp(g))
+
+        var state = initial_state.s;
+        var outputs: ?Tensor = null;
+        var start: i64 = 0;
