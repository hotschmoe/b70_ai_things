+            // inverse stays numerically stable (un-normalized keys make A entries > 1 -> the
+            // alternating series cancels catastrophically in f32 for larger chunks).
+            fn l2norm(x: Tensor) Tensor {
+                const nrm = x.mul(x).sum(.k).sqrt().add(Tensor.scalar(1e-6, .f32));
+                return x.div(nrm.broad(x.shape()));
