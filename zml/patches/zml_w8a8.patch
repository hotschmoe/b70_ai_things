+                if (sh.hasTag(.s) != null) acc = acc.add(Tensor.iota(sh, .s).convert(.f32).scale(ca));
+                if (sh.hasTag(.h) != null) acc = acc.add(Tensor.iota(sh, .h).convert(.f32).scale(cb));
+                if (sh.hasTag(.k) != null) acc = acc.add(Tensor.iota(sh, .k).convert(.f32).scale(cc));
+                if (sh.hasTag(.v) != null) acc = acc.add(Tensor.iota(sh, .v).convert(.f32).scale(cc));
