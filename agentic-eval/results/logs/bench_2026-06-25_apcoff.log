/// A munger which XORs a key with some data
#[derive(Clone)]
pub struct Xorcism<'a> {
    key: &'a [u8],
    key_idx: usize,
}

pub struct XorcismIter<'a, I> {
    xorcism: &'a mut Xorcism<'a>,
    data_iter: I,
}

impl<'a, I: Iterator<Item = u8>> Iterator for XorcismIter<'a, I> {
    type Item = u8;

    fn next(&mut self) -> Option<Self::Item> {
        self.data_iter.next().map(|byte| {
            if self.xorcism.key.is_empty() {
                byte
            } else {
                let key_byte = self.xorcism.key[self.xorcism.key_idx % 
self.xorcism.key.len()];
                self.xorcism.key_idx += 1;
                byte ^ key_byte
            }
        })
    }
}

