        if (!head) throw std::runtime_error("shift from empty list");
        T val = head->data;
        Node* oldHead = head;
        if (head == tail) {
            head = tail = nullptr;
        } else {
            head = head->next;
            head->prev = nullptr;
        }
        delete oldHead;
        size_--;
        return val;
    }

    void unshift(const T& val) {
        Node* newNode = new Node(val);
        if (!head) {
            head = tail = newNode;
        } else {
            head->prev = newNode;
            newNode->next = head;
            head = newNode;
        }
        size_++;
    }

    size_t count() const {
        return size_;
    }

    bool erase(const T& val) {
        Node* current = head;
        while (current) {
            if (current->data == val) {
                if (current == head) {
                    head = head->next;
                    if (head) head->prev = nullptr;
                    else tail = nullptr;
                } else if (current == tail) {
                    tail = tail->prev;
                    if (tail) tail->next = nullptr;
                    else head = nullptr;
                } else {
                    current->prev->next = current->next;
                    current->next->prev = current->prev;
                }
                delete current;
                size_--;
                return true;
            }
            current = current->next;
        }
        return false;
    }
};

}  // namespace linked_list
