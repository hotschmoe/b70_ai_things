    enum Player { BLACK, WHITE, NONE }

    private final char[][] board;
    private final int width;
    private final int height;

    GoCounting(String board) {
        String[] lines = board.split("\n", -1);
        height = lines.length;
        width = lines[0].length();
        this.board = new char[height][width];
        for (int y = 0; y < height; y++) {
            for (int x = 0; x < width; x++) {
                this.board[y][x] = lines[y].charAt(x);
            }
        }
    }

    Player getTerritoryOwner(int x, int y) {
        if (!isValid(x, y) || board[y][x] != ' ') {
            throw new IllegalArgumentException("Invalid point");
        }
        Set<Point> territory = getTerritory(x, y);
        // We can compute owner during territory calculation to avoid 
recomputing,
        // but for simplicity, let's compute it here or refactor getTerritory to
return both.
        // Actually, getTerritory just returns Set<Point>. We can compute owner 
by checking neighbors of the territory.
        Set<Player> owners = new HashSet<>();
        for (Point p : territory) {
            checkNeighbor(p.x, p.y - 1, owners);
            checkNeighbor(p.x, p.y + 1, owners);
            checkNeighbor(p.x - 1, p.y, owners);
            checkNeighbor(p.x + 1, p.y, owners);
        }
        if (owners.isEmpty()) return Player.NONE;
        if (owners.size() == 1) return owners.iterator().next();
        return Player.NONE;
    }

    Set<Point> getTerritory(int x, int y) {
        if (!isValid(x, y) || board[y][x] != ' ') {
            throw new IllegalArgumentException("Invalid point");
        }
        Set<Point> territory = new HashSet<>();
        Queue<Point> queue = new ArrayDeque<>();
        queue.add(new Point(x, y));
        territory.add(new Point(x, y));

        while (!queue.isEmpty()) {
            Point p = queue.poll();
            int[] dx = {0, 0, -1, 1};
            int[] dy = {-1, 1, 0, 0};
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                if (isValid(nx, ny) && board[ny][nx] == ' ' && 
!territory.contains(new Point(nx, ny))) {
                    territory.add(new Point(nx, ny));
                    queue.add(new Point(nx, ny));
                }
            }
        }
        return territory;
    }

    Map<Player, Set<Point>> getTerritories() {
        Map<Player, Set<Point>> territories = new HashMap<>();
        territories.put(Player.BLACK, new HashSet<>());
        territories.put(Player.WHITE, new HashSet<>());
        territories.put(Player.NONE, new HashSet<>());

        boolean[][] visited = new boolean[height][width];
        for (int y = 0; y < height; y++) {
            for (int x = 0; x < width; x++) {
                if (board[y][x] == ' ' && !visited[y][x]) {
                    Set<Point> territory = getTerritory(x, y);
                    for (Point p : territory) {
                        visited[p.y][p.x] = true;
                    }
                    Player owner = getTerritoryOwner(x, y);
                    territories.get(owner).addAll(territory);
                }
            }
        }
        return territories;
    }

    private boolean isValid(int x, int y) {
        return x >= 0 && x < width && y >= 0 && y < height;
    }

    private void checkNeighbor(int x, int y, Set<Player> owners) {
        if (isValid(x, y)) {
            if (board[y][x] == 'B') owners.add(Player.BLACK);
            else if (board[y][x] == 'W') owners.add(Player.WHITE);
        }
    }
}
