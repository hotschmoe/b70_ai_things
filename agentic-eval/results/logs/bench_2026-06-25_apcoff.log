    /// Create a new Xorcism munger from a key
    ///
    /// Should accept anything which has a cheap conversion to a byte slice.
    pub fn new<Key>(key: &Key) -> Xorcism<'a>
    where
        Key: AsRef<[u8]> + ?Sized,
