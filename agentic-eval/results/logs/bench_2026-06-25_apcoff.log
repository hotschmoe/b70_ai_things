import java.awt.Point;
import java.util.*;

class GoCounting {
    private final String[] board;
    private final int width;
    private final int height;

    GoCounting(String board) {
        this.board = board.split("\n");
        this.height = board.length;
        this.width = board[0].length();
    }

    Player getTerritoryOwner(int x, int y) {
        Set<Point> territory = getTerritory(x, y);
        if (territory.isEmpty()) {
            return Player.NONE;
        }
        
        Set<Character> borders = new HashSet<>();
        for (Point p : territory) {
            int[] dx = {-1, 1, 0, 0};
            int[] dy = {0, 0, -1, 1};
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                if (nx >= 0 && nx < width && ny >= 0 && ny < height) {
                    char c = board[ny].charAt(nx);
                    if (c != ' ') {
                        borders.add(c);
                    }
                }
            }
        }
        
        if (borders.size() == 1) {
            char c = borders.iterator().next();
            return c == 'B' ? Player.BLACK : Player.WHITE;
        }
