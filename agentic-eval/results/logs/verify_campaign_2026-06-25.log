/// A munger which XORs a key with some data
#[derive(Clone)]
pub struct Xorcism<'a> {
    key: &'a [u8],
    state: usize,
}

impl<'a> Xorcism<'a> {
    /// Create a new Xorcism munger from a key
    ///
    /// Should accept anything which has a cheap conversion to a byte slice.
    pub fn new<Key>(key: &'a Key) -> Xorcism<'a>
    where
        Key: ?Sized + AsRef<[u8]>,
    {
        Xorcism {
            key: key.as_ref(),
            state: 0,
        }
    }

    /// XOR each byte of the input buffer with a byte from the key.
    ///
    /// Note that this is stateful: repeated calls are likely to produce 
different results,
    /// even with identical inputs.
    pub fn munge_in_place(&mut self, data: &mut [u8]) {
        for byte in data.iter_mut() {
            if !self.key.is_empty() {
                *byte ^= self.key[self.state];
                self.state = (self.state + 1) % self.key.len();
            }
        }
    }

    /// XOR each byte of the data with a byte from the key.
    ///
    /// Note that this is stateful: repeated calls are likely to produce 
different results,
    /// even with identical inputs.
    ///
    /// Should accept anything which has a cheap conversion to a byte iterator.
    /// Shouldn't matter whether the byte iterator's values are owned or 
borrowed.
    pub fn munge<Data>(&mut self, data: Data) -> impl Iterator<Item = u8> + '_
    where
        Data: IntoIterator,
        Data::Item: Into<u8>,
    {
        let key = self.key;
        let state = &mut self.state;
        data.into_iter().map(move |b| {
            let byte = b.into();
            if key.is_empty() {
                byte
            } else {
                let res = byte ^ key[*state];
                *state = (*state + 1) % key.len();
                res
            }
        })
    }
}
```

