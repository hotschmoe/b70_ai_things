import java.awt.Point;
import java.util.Map;
import java.util.Set;
import java.util.HashSet;
import java.util.HashMap;
import java.util.Queue;
import java.util.ArrayDeque;

class GoCounting {
    private final char[][] board;
    private final int width;
    private final int height;

    GoCounting(String board) {
        String[] lines = board.split("\n", -1);
        height = lines.length;
        width = lines[0].length();
        this.board = new char[height][width];
        for (int y = 0; y < height; y++) {
            this.board[y] = lines[y].toCharArray();
        }
    }

    private void validate(int x, int y) {
        if (x < 0 || x >= width || y < 0 || y >= height) {
            throw new IllegalArgumentException("Invalid point");
        }
    }

    Player getTerritoryOwner(int x, int y) {
        validate(x, y);
        if (board[y][x] != ' ') {
            return Player.NONE;
        }
        
        Set<Point> visited = new HashSet<>();
        Queue<Point> queue = new ArrayDeque<>();
        queue.add(new Point(x, y));
        visited.add(new Point(x, y));
        
        boolean touchesBlack = false;
        boolean touchesWhite = false;
        
        int[] dx = {1, -1, 0, 0};
        int[] dy = {0, 0, 1, -1};
        
        while (!queue.isEmpty()) {
            Point p = queue.poll();
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                
                if (nx >= 0 && nx < width && ny >= 0 && ny < height) {
                    char c = board[ny][nx];
                    if (c == ' ') {
                        Point np = new Point(nx, ny);
                        if (!visited.contains(np)) {
                            visited.add(np);
                            queue.add(np);
                        }
                    } else if (c == 'B') {
                        touchesBlack = true;
                    } else if (c == 'W') {
                        touchesWhite = true;
                    }
                }
            }
        }
        
        if (touchesBlack && !touchesWhite) return Player.BLACK;
        if (touchesWhite && !touchesBlack) return Player.WHITE;
        return Player.NONE;
    }

    Set<Point> getTerritory(int x, int y) {
        validate(x, y);
        if (board[y][x] != ' ') {
            return Set.of();
        }
        
        Set<Point> territory = new HashSet<>();
        Set<Point> visited = new HashSet<>();
        Queue<Point> queue = new ArrayDeque<>();
        
        queue.add(new Point(x, y));
        visited.add(new Point(x, y));
        
        int[] dx = {1, -1, 0, 0};
        int[] dy = {0, 0, 1, -1};
        
        while (!queue.isEmpty()) {
            Point p = queue.poll();
            territory.add(p);
            
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                
                if (nx >= 0 && nx < width && ny >= 0 && ny < height) {
                    char c = board[ny][nx];
                    if (c == ' ') {
                        Point np = new Point(nx, ny);
                        if (!visited.contains(np)) {
                            visited.add(np);
                            queue.add(np);
                        }
                    }
                }
            }
        }
        
        return territory;
    }

    Map<Player, Set<Point>> getTerritories() {
        Map<Player, Set<Point>> territories = new HashMap<>();
        territories.put(Player.BLACK, new HashSet<>());
        territories.put(Player.WHITE, new HashSet<>());
        territories.put(Player.NONE, new HashSet<>());
        
        Set<Point> visited = new HashSet<>();
        
        for (int y = 0; y < height; y++) {
            for (int x = 0; x < width; x++) {
                if (board[y][x] == ' ' && !visited.contains(new Point(x, y))) {
                    Set<Point> territory = getTerritory(x, y);
                    visited.addAll(territory);
                    Player owner = getTerritoryOwner(x, y);
                    territories.get(owner).addAll(territory);
                }
            }
        }
        
        return territories;
    }
}
