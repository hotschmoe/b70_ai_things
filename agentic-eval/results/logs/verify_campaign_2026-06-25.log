                        for i := 0; i < len(bytes); i++ {
                                if i < len(bytes)-1 {
                                        result = append(result, bytes[i]|0x80)
                                } else {
                                        result = append(result, bytes[i])
                                }
                        }
                }
        }
        return result
}
```

