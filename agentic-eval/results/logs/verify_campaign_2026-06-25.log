```java
import java.awt.Point;
import java.util.*;

class GoCounting {

    private final String[] board;
    private final int width;
    private final int height;

    GoCounting(String board) {
        this.board = board.split("\n");
        this.height = this.board.length;
        this.width = this.board[0].length();
    }

    Player getTerritoryOwner(int x, int y) {
        if (!isValid(x, y)) {
            throw new IllegalArgumentException("Invalid point");
        }
        if (board[y].charAt(x) != ' ') {
            return Player.NONE;
        }
        
        Set<Point> territory = getTerritory(x, y);
        Set<Player> owners = new HashSet<>();
        for (Point p : territory) {
            for (Point neighbor : getNeighbors(p)) {
                if (isValid(neighbor.x, neighbor.y)) {
                    char c = board[neighbor.y].charAt(neighbor.x);
                    if (c == 'B') owners.add(Player.BLACK);
                    else if (c == 'W') owners.add(Player.WHITE);
                }
            }
        }
        
        if (owners.size() == 1) {
            return owners.iterator().next();
        }
        return Player.NONE;
    }

    Set<Point> getTerritory(int x, int y) {
        if (!isValid(x, y)) {
            throw new IllegalArgumentException("Invalid point");
        }
        if (board[y].charAt(x) != ' ') {
            return Collections.emptySet();
        }
        
        Set<Point> territory = new HashSet<>();
        Queue<Point> queue = new ArrayDeque<>();
        Set<Point> visited = new HashSet<>();
        
        Point start = new Point(x, y);
        queue.add(start);
        visited.add(start);
        
        while (!queue.isEmpty()) {
            Point current = queue.poll();
            territory.add(current);
            
            for (Point neighbor : getNeighbors(current)) {
                if (isValid(neighbor.x, neighbor.y) && 
                    board[neighbor.y].charAt(neighbor.x) == ' ' && 
                    !visited.contains(neighbor)) {
                    visited.add(neighbor);
                    queue.add(neighbor);
                }
            }
        }
        return territory;
    }

    Map<Player, Set<Point>> getTerritories() {
        Map<Player, Set<Point>> territories = new EnumMap<>(Player.class);
        territories.put(Player.BLACK, new HashSet<>());
        territories.put(Player.WHITE, new HashSet<>());
        territories.put(Player.NONE, new HashSet<>());
        
        Set<Point> visited = new HashSet<>();
        for (int y = 0; y < height; y++) {
            for (int x = 0; x < width; x++) {
                if (board[y].charAt(x) == ' ' && !visited.contains(new Point(x, 
y))) {
                    Set<Point> territory = getTerritory(x, y);
                    visited.addAll(territory);
                    Player owner = getTerritoryOwner(x, y);
                    territories.get(owner).addAll(territory);
                }
            }
        }
        return territories;
    }
    
    private boolean isValid(int x, int y) {
        return x >= 0 && x < width && y >= 0 && y < height;
    }
    
    private List<Point> getNeighbors(Point p) {
        List<Point> neighbors = new ArrayList<>();
        int[] dx = {0, 0, 1, -1};
        int[] dy = {1, -1, 0, 0};
        for (int i = 0; i < 4; i++) {
            neighbors.add(new Point(p.x + dx[i], p.y + dy[i]));
        }
        return neighbors;
    }
}

enum Player {
    BLACK, WHITE, NONE
}
