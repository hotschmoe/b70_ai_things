export const answer = (question) => {
  if (!question.startsWith('What is ') || !question.endsWith('?')) {
    throw new Error('Unknown operation'); // or 'Syntax error' depending on 
tests, usually 'Syntax error' or 'Unknown operation'
  }

  let expr = question.slice(8, -1); // remove "What is " and "?"
  
  // Normalize operations
  expr = expr.replace(/multiplied by/g, 'multiplied');
  expr = expr.replace(/divided by/g, 'divided');
  
  const tokens = expr.split(' ');
  
  if (tokens.length === 0 || tokens[0] === '') {
    throw new Error('Syntax error');
  }
  
  let result = parseInt(tokens[0], 10);
  if (isNaN(result)) {
    throw new Error('Syntax error');
  }
  
  for (let i = 1; i < tokens.length; i += 2) {
    const op = tokens[i];
    const numStr = tokens[i + 1];
    
    if (!numStr || isNaN(parseInt(numStr, 10))) {
      throw new Error('Syntax error');
    }
    
    const num = parseInt(numStr, 10);
    
    switch (op) {
      case 'plus':
        result += num;
        break;
      case 'minus':
        result -= num;
        break;
      case 'multiplied':
        result *= num;
        break;
      case 'divided':
        result /= num;
        break;
      default:
        throw new Error('Unknown operation');
    }
  }
  
  return result;
};
```

