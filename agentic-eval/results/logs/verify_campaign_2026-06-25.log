func EncodeVarint(input []uint32) []byte {
        var result []byte
        for _, v := range input {
                if v == 0 {
                        result = append(result, 0x00)
                } else {
                        var bytes []byte
                        for v > 0 {
                                bytes = append(bytes, uint8(v&0x7F))
                                v >>= 7
