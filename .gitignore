# Secrets — never commit
*.token
.hf_token
*_token*
*secret*
.env
*.pem
id_*
*.key

# OS / editor cruft
Thumbs.db
desktop.ini
.DS_Store
*.swp
*~

# Local scratch
tmp/
*.tmp

# new-backend runtime artifacts: DP=2 nginx conf is generated at serve time; serve logs are runtime
llamacpp/.dp_nginx.conf
llamacpp/*.log
zml/*.log

# Soft-delete bin -- stale/superseded docs parked here for manual review, then purged.
# Untracked on purpose; never committed.
archive/

# Large raw model/bench dumps stay on the box; curated results live in results/*.csv + RESULTS.md
*.gguf
*.safetensors
__pycache__/

# localmaxxing API puller (scripts/75) -- large regenerable raw dumps stay local;
# the curated data/localmaxxing/b70_summary.md snapshot IS tracked.
data/localmaxxing/*_raw.json

# local secrets (API keys) -- never commit
.secrets/
*.secret

# agentic-eval: per-harness uv venvs, datasets, native harness outputs, and raw run data are
# regenerable/large -> stay local. The curated results/{scores.json,SUMMARY.md} ARE tracked.
agentic-eval/harnesses/*/.venv/
agentic-eval/harnesses/*/data/
agentic-eval/harnesses/*/runs/
agentic-eval/harnesses/*/work/
agentic-eval/harnesses/*/.cache/
# cloned/vendored upstream harness checkouts (regenerated by each setup.sh; never embed as a gitlink)
agentic-eval/harnesses/*/src/
agentic-eval/harnesses/*/vendor/
agentic-eval/results/*/.*.parsed.json
agentic-eval/results/*/raw/
agentic-eval/tasks/
